{
  "expo": {
    "name": "GymSync",
    "slug": "gymsync",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "gymsync",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gymsync.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "GymSync needs camera access to log your workouts with photos.",
        "NSPhotoLibraryUsageDescription": "GymSync needs photo library access to select workout photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.gymsync.app"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      [
        "expo-image-picker",
        {
          "cameraPermission": "GymSync needs camera access to log your workouts with photos.",
          "photosPermission": "GymSync needs photo library access to select workout photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#F9C38E"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-secure-store",
      "./plugins/widget/withWidget"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
